# Environment Configuration
NODE_ENV=development
PORT=3000
VERTICAL=core

# AWS Secrets Manager (RDS)
AWS_REGION=ap-south-1
AWS_RDS_SECRET_NAME=rds!db-4fd76536-90f2-4bd6-8da2-370b56d1312f

# Database (AWS RDS PostgreSQL - loaded from Secrets Manager)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=
DATABASE_NAME=meru_core

# JWT
JWT_SECRET=your-jwt-secret
JWT_EXPIRATION=1h

# Cache (Optional - Redis)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# AI Configuration
OPENAI_API_KEY=your-openai-api-key

# Search Configuration (Optional - MeiliSearch)
# MEILISEARCH_HOST=http://localhost:7700
# MEILISEARCH_MASTER_KEY=your-meilisearch-key

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=meru-documents

# Document Configuration
DOCUMENT_ENCRYPTION_KEY=your-32-character-encryption-key-here
MAX_FILE_SIZE=52428800

# Base Domain (for vertical subdomains)
BASE_DOMAIN=meru.com

# Testing (for local development with query params)
TEST_TENANT_SLUG=acme-company
TEST_VERTICAL_SLUG=immigration
